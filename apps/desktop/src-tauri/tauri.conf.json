{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CHIE Node",
  "version": "0.1.0",
  "identifier": "com.chie.node",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "CHIE Node",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [],
    "category": "Utility",
    "shortDescription": "CHIE Protocol Node Client",
    "longDescription": "Desktop client for running a CHIE Protocol node, earning rewards by sharing bandwidth and storage.",
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "wix": null,
      "nsis": null
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
